# VITE_GEMINI_API_KEY: Preferred for local/native Vite builds.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_API_KEY: Legacy AI Studio secret fallback. The Vite config maps this into the client bundle.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_PARENT_API_URL: The RayHealth web API base used by the mobile shell.
VITE_PARENT_API_URL="https://rayhealthevv.com/api"
