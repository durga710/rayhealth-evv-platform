{
  "expo": {
    "name": "RayHealth EVV",
    "slug": "rayhealth-evv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rayhealthevv",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.rayhealth.evv",
      "supportsTablet": true
    },
    "android": {
      "package": "com.rayhealth.evv",
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_ANDROID_MAPS_API_KEY"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1a5fa8",
          "defaultChannel": "shift-alerts"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RayHealthEVV uses your location only while you clock in or out, to verify you are at the client's address for Electronic Visit Verification.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "https://rayhealthevv.com"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
