{
  "name": "@rayhealth/core",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc --composite false",
    "db:migrate": "tsx src/migrations/runner.ts",
    "lint": "eslint . --ext ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "knex": "^3.2.10",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  }
}
