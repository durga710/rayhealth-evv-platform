{
  "name": "@rayhealth/core",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --composite false",
    "db:migrate": "tsx src/migrations/runner.ts",
    "db:seed:learning": "tsx scripts/seed-learning-catalog.ts",
    "lint": "eslint . --ext ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/ssh2-sftp-client": "^9.0.6",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "knex": "^3.3.0",
    "pg": "^8.22.0",
    "ssh2-sftp-client": "^12.1.1",
    "zod": "^4.4.3"
  }
}
