{
  "installCommand": "npm install --include=dev --workspaces --include-workspace-root && ls -la node_modules/.bin/tsc node_modules/.bin/turbo 2>&1 | head -5",
  "buildCommand": "node_modules/.bin/turbo build --filter=@rayhealth/web --filter=@rayhealth/app --filter=@rayhealth/core",
  "outputDirectory": "packages/web/dist",
  "functions": {
    "api/index.mts": {
      "runtime": "@vercel/node@5.0.0",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.mts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}