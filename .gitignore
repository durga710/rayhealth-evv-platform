# Dependencies
node_modules/
**/node_modules/

# Build artifacts
dist/
**/dist/
# packages/core/dist and packages/app/dist are still committed because the
# monorepo's TypeScript resolution consumes core/app at compile time via dist.
# packages/web/dist is now built by Vercel on every deploy (see vercel.json) —
# no need to commit web build output.
!packages/core/dist/
!packages/app/dist/
.turbo/
**/.turbo/
*.tsbuildinfo

# Environment files — NEVER commit. Real values live in Vercel project env vars.
.env
.env.*
!.env.example

# Vercel
.vercel

# Tooling caches
.superpowers/
.claude/

# OS / editors
.DS_Store
*.swp
.idea/
.vscode/

# Logs
*.log
turbo-*.log

# Test / E2E output — generated, never commit (screenshots, video, traces, runs)
e2e-artifacts/
**/test-results/
**/playwright-report/
**/.last-run.json
coverage/
**/coverage/

# Ad-hoc working notes & status dumps — keep durable docs in docs/ instead
DEPLOY_NOW.md
PROGRESS.html
PROJECT_STATUS.md
HANDOFF*.md
