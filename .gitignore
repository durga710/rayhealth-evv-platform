# Dependencies
node_modules/
**/node_modules/

# Build artifacts
dist/
**/dist/
# No dist is committed. Vercel's build now compiles the workspace deps itself
# (buildCommand runs `turbo build` for @rayhealth/web + @rayhealth/app and
# their dependencies), so core/app/web dist are all produced at deploy time.
.turbo/
**/.turbo/
*.tsbuildinfo

# Environment files — NEVER commit. Real values live in Vercel project env vars.
.env
.env.*
!.env.example

# Vercel
.vercel

# Tooling caches
.superpowers/
.claude/

# OS / editors
.DS_Store
*.swp
.idea/
.vscode/

# Logs
*.log
turbo-*.log

# Test / E2E output — generated, never commit (screenshots, video, traces, runs)
e2e-artifacts/
**/test-results/
**/playwright-report/
**/.last-run.json
coverage/
**/coverage/

# Ad-hoc working notes & status dumps — keep durable docs in docs/ instead
DEPLOY_NOW.md
PROGRESS.html
PROJECT_STATUS.md
HANDOFF*.md

# Stray Google Cloud SDK installs — a mis-run `gcloud components install ...`
# once created a multi-hundred-MB directory named after the command itself in
# the repo root. Never commit the SDK or its artifacts.
google-cloud-sdk/
gcloud components install*/
GEMINI.md
