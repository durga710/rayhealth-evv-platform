# RayHealth EVV — environment variable template.
# Copy to .env (local dev) or set in Vercel project env (prod / preview).
# NEVER commit real values; .env and .env.* are gitignored.

# --- Runtime ---
NODE_ENV=development

# --- Core API ---
# Use DATABASE_URL OR the discrete DB_* fields below.
DATABASE_URL=postgres://user:password@host:5432/rayhealth
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rayhealth
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
CSRF_SECRET=
ENCRYPTION_KEY=
# Required for /auth/bootstrap. Leave UNSET in production after the first
# admin is bootstrapped — that fully disables the endpoint.
BOOTSTRAP_SECRET=
LOG_LEVEL=info
CORS_ORIGIN=
ALLOWED_ORIGINS=

# --- URLs ---
API_URL=
APP_URL=
BASE_URL=

# --- Firebase (auth / messaging) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_STORAGE_BUCKET=

# --- Google Identity Platform / OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_IDENTITY_PLATFORM_PROJECT_ID=
VITE_GOOGLE_CLIENT_ID=

# --- AWS Bedrock ---
AWS_REGION=
AWS_BEARER_TOKEN_BEDROCK=

# --- AI providers ---
RAY_AI_PROVIDER=
RAY_OPENAI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Email ---
RESEND_API_KEY=
RESEND_FROM_ADDRESS=
RESEND_REPLY_TO=

# --- Payments ---
STRIPE_SECRET_KEY=
