# RayHealth EVV — environment variable template.
# Copy to .env (local dev) or set in Vercel project env (prod / preview).
# NEVER commit real values; .env and .env.* are gitignored.

# --- Runtime ---
NODE_ENV=development

# --- Core API ---
# Use DATABASE_URL OR the discrete DB_* fields below.
DATABASE_URL=postgres://user:password@host:5432/rayhealth
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rayhealth
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
CSRF_SECRET=
ENCRYPTION_KEY=
# Required for /auth/bootstrap. Leave UNSET in production after the first
# admin is bootstrapped — that fully disables the endpoint.
BOOTSTRAP_SECRET=
LOG_LEVEL=info
CORS_ORIGIN=
ALLOWED_ORIGINS=

# --- URLs ---
API_URL=
APP_URL=
BASE_URL=

# --- Firebase (auth / messaging) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_STORAGE_BUCKET=

# --- Google Identity Platform / OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_IDENTITY_PLATFORM_PROJECT_ID=
VITE_GOOGLE_CLIENT_ID=

# --- AWS Bedrock (HIPAA-eligible inference for both AI assistants) ---
# AWS_REGION required (e.g. us-east-1). Credentials are picked up by the
# default SDK chain — set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY for an
# IAM user, OR AWS_BEARER_TOKEN_BEDROCK for a short-lived Bedrock token,
# OR rely on an attached IAM role (no env vars needed in that case).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEARER_TOKEN_BEDROCK=
# Optional override; default is us.anthropic.claude-haiku-4-5-20251001-v1:0
# (cheap + fast cross-region inference profile). Both /api/support/chat
# and /api/admin-assistant/chat read this.
BEDROCK_MODEL_ID=

# --- Document storage (AWS S3, BAA-covered) ---
# Prior-authorization PDFs are stored in this private S3 bucket with SSE-S3
# encryption at rest; reads go through short-lived presigned URLs only. Reuses
# the AWS credentials above. DOCUMENTS_S3_REGION defaults to AWS_REGION.
DOCUMENTS_S3_BUCKET=
DOCUMENTS_S3_REGION=

# --- AI providers ---
# AWS Bedrock (above) is the ONLY AI provider. It is the only AI vendor under a
# signed BAA, and PHI flows through the copilot / command-center AI surfaces, so
# there is deliberately no non-BAA fallback. GOOGLE_AI_API_KEY / GEMINI_API_KEY
# must NOT be set in production — the app refuses to boot if they are.
RAY_AI_PROVIDER=
RAY_OPENAI_API_KEY=
OPENAI_API_KEY=

# --- Email (Amazon SES) ---
# Required to actually deliver staff-invite emails. If either AWS_ACCESS_KEY_ID
# or AWS_SECRET_ACCESS_KEY is unset, the API falls back to the manual-copy
# flow: invite is created and the admin gets the URL to share by hand.
# No crash on startup.
#
# These should be the credentials for an IAM user with ses:SendEmail
# permission only — NOT your AWS root account.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Region where your SES domain identity is verified. Must match the region
# in your DKIM CNAME records (e.g. feedback-smtp.us-west-2.amazonses.com).
AWS_SES_REGION=us-west-2
# Verified sender — the local part can be anything, but the @-domain must
# match a verified SES identity. Format: "Display Name <local@domain>".
EMAIL_FROM=RayHealth <onboarding@rayhealthevv.com>
# Absolute origin used when composing invite URLs in the email body.
# Set this to your production domain in Vercel (e.g. https://rayhealthevv.com).
# Falls back to APP_URL, then BASE_URL, then http://localhost:5173.
INVITE_URL_BASE=https://rayhealthevv.com

# --- Payments ---
STRIPE_SECRET_KEY=
