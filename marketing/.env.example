# marketing/.env.example
#
# Copy this file to marketing/.env (which is gitignored) and fill in your
# real keys. NEVER commit marketing/.env. NEVER paste these values into chat.
#
#   cp marketing/.env.example marketing/.env
#   chmod 600 marketing/.env
#   # then edit marketing/.env in your editor of choice
#
# Verify .env is gitignored before saving anything real:
#   git check-ignore marketing/.env
#   # should print: marketing/.env

# ElevenLabs — voice generation
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_REPLACE_ME

# Google AI / Gemini API — Veo 3 video generation
# Get yours at: https://aistudio.google.com/apikey
# Restrict the key to Generative Language API only, ideally by IP.
GOOGLE_AI_API_KEY=AIza_REPLACE_ME

# fal.ai — Seedance video generation (alternative to Veo 3)
# Get yours at: https://fal.ai/dashboard/keys
# Only needed if you want to use the Seedance pipeline instead of Veo 3.
FAL_KEY=REPLACE_ME
