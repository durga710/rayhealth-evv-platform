{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@rayhealth/core/*": ["packages/core/src/*"],
      "@rayhealth/app/*": ["packages/app/src/*"],
      "@rayhealth/web/*": ["packages/web/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
